# Anthropic (LLM for intent detection, persona responses, vision on images)
ANTHROPIC_API_KEY=

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# Embedding provider for the RAG vector store: "huggingface" (local, free) or "anthropic-voyage"
EMBEDDING_PROVIDER=huggingface

# Paths
PRODUCTS_CSV_PATH=data/products_500.csv
CHROMA_PERSIST_DIR=data/chroma_store
CHECKPOINT_DB_PATH=data/checkpoints.sqlite
APP_DB_PATH=data/app_state.sqlite

# Follow-up timers (seconds) - defaults match spec: 1 hour inactivity, 48 hours no purchase
INACTIVITY_FOLLOWUP_SECONDS=3600
NO_PURCHASE_FOLLOWUP_SECONDS=172800

# Discount code shown in the 48h follow-up
DISCOUNT_CODE=BAZARYAR10
